# Copy this file to deploy/gcp/ghreplica.env on the VM and fill in the values.

# Cloud SQL instance connection name, for example:
# horse-460221:europe-west1:horse-pg
CLOUD_SQL_INSTANCE_CONNECTION_NAME=

# Database name already provisioned for ghreplica.
DB_NAME=ghreplica

# URL-encoded IAM database username for the service account, for example:
# bob-gcloud%40dutiful-20260414.iam
DB_IAM_USER_URLENCODED=

# GitHub access for upstream sync.
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Optional GitHub App settings. Leave blank if using a PAT.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
