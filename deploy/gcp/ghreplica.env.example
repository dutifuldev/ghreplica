# Copy this file to deploy/gcp/ghreplica.env on the VM and fill in the values.

# Cloud SQL instance connection name, for example:
# horse-460221:europe-west1:horse-pg
CLOUD_SQL_INSTANCE_CONNECTION_NAME=

# Database name already provisioned for ghreplica.
DB_NAME=ghreplica

# URL-encoded IAM database username for the service account, for example:
# bob-gcloud%40dutiful-20260414.iam
DB_IAM_USER_URLENCODED=

# GitHub webhook secret configured on the App.
GITHUB_WEBHOOK_SECRET=

# GitHub App identity.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=

# Absolute path on the VM to the GitHub App private key PEM file.
# Recommended location:
# /home/bob/ghreplica/secrets/github-app.private-key.pem
GITHUB_APP_PRIVATE_KEY_PATH=

# Leave blank when using api.github.com.
GITHUB_BASE_URL=

# PAT support. Leave blank when using a GitHub App.
GITHUB_TOKEN=

# Serve runtime pool sizing. These values keep River and API reads off the floor
# while leaving headroom for sync work and Cloud SQL reserved slots.
DB_CONTROL_MAX_OPEN_CONNS=6
DB_CONTROL_MAX_IDLE_CONNS=2
DB_SYNC_MAX_OPEN_CONNS=8
DB_SYNC_MAX_IDLE_CONNS=2

# Background webhook projection stays conservative; the control pool is now large
# enough to support River plus API reads without starving the queue control plane.
WEBHOOK_JOB_QUEUE_CONCURRENCY=1
WEBHOOK_JOB_TIMEOUT=30s
WEBHOOK_JOB_MAX_ATTEMPTS=8
